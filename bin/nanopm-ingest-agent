#!/usr/bin/env python3
"""nanopm-ingest-agent — deterministic bookkeeping mechanics for the memory wiki.

Part of the memory-wiki redesign (issue #105). The "ingest/bookkeeper" is two
halves:

  1. The REASONING half (what to integrate from a source, which entity pages to
     touch, how to phrase a claim) is done by an LLM subagent the main agent
     dispatches — see `nanopm_ingest_prompt` in lib/nanopm.sh.
  2. The DETERMINISTIC half (this script) is the bookkeeping that needs no LLM:
     dedup a claim by its citation before writing, write the page directly (a
     locked, single-writer-per-file write — `apply`), regenerate the index, and
     append to the log. There is no pre-write confidence gate (NANOPM-WIKI.md §11):
     quality is enforced after the fact by the judgment lint pass.

Keeping the mechanics here (not in the subagent) is what makes ingest idempotent
and host-agnostic: the same commands run on Claude / Vibe / Codex, and on a host
without an Agent tool the main agent calls them inline (the graceful fallback).

Subcommands:
  reindex          regenerate .nanopm/wiki/index.md from page frontmatter
  log              append a heartbeat line to .nanopm/wiki/log.md
  citation-check   is a citation already on a page? (dedup gate — NEW vs DUPLICATE)
  apply            write a wiki page directly (locked, single-writer-per-file)
  raw-check        is a raw source already archived? (content-hash dedup — see below)
  sync             push all local wiki pages to Supabase (bulk upsert — requires config)
  pull             fetch wiki pages updated on Supabase to local wiki (newest wins; local hand edits protected)
  push-file        push a single wiki file to Supabase (called by nanopm_wiki_doc_log)
  status           show which local pages were modified since the last Supabase sync (offline)
  search-index     build/rebuild the SQLite FTS5 search index (.nanopm/search.db)
  search           query the search index (auto-rebuilds if stale)

Usage:
  nanopm-ingest-agent reindex [--project DIR]
  nanopm-ingest-agent log --op ingest --title "Theo interview 2026-06-23" [--project DIR]
  nanopm-ingest-agent citation-check --target wiki/entities/personas/theo.md \\
      --citation '"I live in the terminal" — interview, 2026-06-23' [--project DIR]
  nanopm-ingest-agent apply --target wiki/entities/personas/theo.md [--project DIR] < content.md
  nanopm-ingest-agent raw-check --type feedback --hash 9f86d081884c [--project DIR]
  nanopm-ingest-agent raw-check --type feedback < source.txt   # hash stdin, then check
  nanopm-ingest-agent search-index [--project DIR]
  nanopm-ingest-agent search --query "context fatigue" [--type opportunities] [--limit 5] [--project DIR]

Exit codes: reindex/log/apply/search-index -> 0 ok, 1 error.
            citation-check/raw-check -> 0 DUPLICATE, 1 NEW, 2 error.
            search -> 0 ok (prints NO_RESULTS if nothing matched), 1 error.
"""
from __future__ import annotations

import argparse
import contextlib
import datetime as _dt
import hashlib
import json as _json
import sqlite3
import sys
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

try:
    import fcntl  # POSIX (macOS / Linux) — nanopm's supported hosts
except ImportError:  # pragma: no cover — non-POSIX: degrade to no locking
    fcntl = None

SUPABASE_PAGES_TABLE    = "nanopm_wiki_pages"
SUPABASE_RAW_TABLE      = "nanopm_raw_sources"
SUPABASE_PROJECTS_TABLE = "nanopm_projects"


def _supabase_creds() -> tuple[str | None, str | None]:
    """Return (url, key) for Supabase.
    Resolution order: env vars → ~/.nanopm/.env file."""
    import os
    url = os.environ.get("NANOPM_SUPABASE_URL")
    key = os.environ.get("NANOPM_SUPABASE_KEY")
    if not url or not key:
        env_file = Path.home() / ".nanopm" / ".env"
        if env_file.is_file():
            for line in env_file.read_text(encoding="utf-8", errors="replace").splitlines():
                line = line.strip()
                if line.startswith("#") or "=" not in line:
                    continue
                k, _, v = line.partition("=")
                v = v.strip().strip("\"'")
                if k == "NANOPM_SUPABASE_URL" and not url:
                    url = v
                elif k == "NANOPM_SUPABASE_KEY" and not key:
                    key = v
    return url or None, key or None


# ---------------------------------------------------------------------------
# Sync-state: content-hash tracking for push/pull conflict detection
# ---------------------------------------------------------------------------
# After every successful push or pull we record sha256(content) per wiki path
# in ~/.nanopm/sync-state/{project_slug}.json.  On the next pull we can tell
# whether the local file was hand-edited since the last sync (hash diverged)
# rather than relying solely on the `last_updated` frontmatter timestamp, which
# is only bumped by skills — not by hand edits.

def _sync_state_path(project: str) -> Path:
    state_dir = Path.home() / ".nanopm" / "sync-state"
    state_dir.mkdir(parents=True, exist_ok=True)
    # Use full resolved path hash so two repos with the same directory name
    # (e.g. ~/work/alpha and ~/clients/alpha) don't share the same state file.
    full_path = str(Path(project).resolve())
    key = hashlib.sha256(full_path.encode()).hexdigest()[:16]
    slug = Path(project).resolve().name
    new_path = state_dir / f"{slug}-{key}.json"
    # One-time migration: move slug-only state file to the new slug+hash name.
    old_path = state_dir / f"{slug}.json"
    if old_path.is_file() and not new_path.is_file():
        try:
            old_path.rename(new_path)
        except OSError:
            pass
    return new_path

def _load_sync_state(project: str) -> dict:
    p = _sync_state_path(project)
    if p.is_file():
        try:
            return _json.loads(p.read_text(encoding="utf-8"))
        except Exception:
            return {}
    return {}

def _save_sync_state(project: str, state: dict) -> None:
    try:
        _sync_state_path(project).write_text(_json.dumps(state, indent=2), encoding="utf-8")
    except Exception:
        pass

def _content_hash(content: str) -> str:
    return hashlib.sha256(content.encode("utf-8", errors="replace")).hexdigest()


def _supabase_ensure_project(project: str) -> None:
    """Register this project in the nanopm_projects table (the multi-tenant registry).

    The wiki/raw tables are already multi-tenant — every row carries project_slug and
    a shared Supabase instance holds many projects (no DB-per-project). But nothing
    enumerates *which* projects live there; nanopm_projects is that registry (one row
    per project), so a shared DB is self-describing and a teammate's viewer can list
    projects instead of having to know each slug.

    Fires ONE insert per project: guarded by a '__project_registered__' sentinel in the
    per-project sync-state (keys are looked up by exact path elsewhere, never iterated,
    so the sentinel is inert), so it never adds a per-page HTTP call on bulk sync or the
    per-write auto-push. Uses ignore-duplicates so an existing/edited registry row is
    never clobbered. Best-effort — never raises; the page/raw push already succeeded."""
    url, key = _supabase_creds()
    if not url or not key:
        return
    project_slug = Path(project).resolve().name
    state = _load_sync_state(project)
    if state.get("__project_registered__") == project_slug:
        return
    try:
        req = urllib.request.Request(
            f"{url}/rest/v1/{SUPABASE_PROJECTS_TABLE}",
            data=_json.dumps({"slug": project_slug, "name": project_slug}).encode(),
            headers={
                "apikey": key,
                "Authorization": f"Bearer {key}",
                "Content-Type": "application/json",
                "Prefer": "resolution=ignore-duplicates",
            },
            method="POST",
        )
        urllib.request.urlopen(req, timeout=5)
        state["__project_registered__"] = project_slug
        _save_sync_state(project, state)
    except Exception:
        pass  # registry is best-effort; the page/raw sync already succeeded


def _supabase_upsert_page(project: str, rel_path: str, content: str) -> None:
    """Upsert one wiki page to Supabase. Best-effort — never raises."""
    url, key = _supabase_creds()
    if not url or not key:
        return
    _supabase_ensure_project(project)
    try:
        fm, body = parse_frontmatter(content)
        project_slug = Path(project).resolve().name
        row = {
            "project_slug": project_slug,
            "path": rel_path,
            "slug": fm.get("slug", ""),
            "type": fm.get("type", ""),
            "provenance": fm.get("provenance", ""),
            "priority": fm.get("priority", ""),
            "title": fm.get("title") or Path(rel_path).stem.replace("-", " "),
            "theme": fm.get("theme", ""),
            "summary": _truncate(summary_line(body)),
            "body": body,
            "content": content,
            "last_updated": fm.get("last_updated") or fm.get("generated", ""),
        }
        endpoint = f"{url}/rest/v1/{SUPABASE_PAGES_TABLE}?on_conflict=project_slug,path"
        req = urllib.request.Request(
            endpoint,
            data=_json.dumps(row).encode(),
            headers={
                "apikey": key,
                "Authorization": f"Bearer {key}",
                "Content-Type": "application/json",
                "Prefer": "resolution=merge-duplicates",
            },
            method="POST",
        )
        urllib.request.urlopen(req, timeout=5)
        # Push succeeded — record hash as the new sync baseline
        state = _load_sync_state(project)
        state[rel_path] = _content_hash(content)
        _save_sync_state(project, state)
    except Exception:
        pass  # best-effort: local write already succeeded


def _supabase_log_entry(project: str, op: str, title: str, day: str) -> None:
    """Mirror a wiki log heartbeat to Supabase. Best-effort — never raises."""
    url, key = _supabase_creds()
    if not url or not key:
        return
    try:
        project_slug = Path(project).resolve().name
        row = {"project_slug": project_slug, "op": op, "title": title, "day": day}
        req = urllib.request.Request(
            f"{url}/rest/v1/nanopm_wiki_log",
            data=_json.dumps(row).encode(),
            headers={
                "apikey": key,
                "Authorization": f"Bearer {key}",
                "Content-Type": "application/json",
            },
            method="POST",
        )
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        pass


def _supabase_upsert_raw(project: str, rel_path: str, content: str) -> None:
    """Upsert one raw source file to Supabase. Best-effort — never raises."""
    url, key = _supabase_creds()
    if not url or not key:
        return
    _supabase_ensure_project(project)
    try:
        project_slug = Path(project).resolve().name
        parts = Path(rel_path).parts
        raw_type = parts[0] if parts else ""
        stem = Path(rel_path).name.split(".")[0]
        raw_id = stem if len(stem) == 12 and all(c in "0123456789abcdef" for c in stem) else None
        content_hash = _content_hash(content)
        row = {
            "project_slug": project_slug,
            "type": raw_type,
            "raw_id": raw_id,
            "path": rel_path,
            "content": content,
            "content_hash": content_hash,
            "file_size": len(content.encode("utf-8", errors="replace")),
        }
        req = urllib.request.Request(
            f"{url}/rest/v1/{SUPABASE_RAW_TABLE}?on_conflict=project_slug,path",
            data=_json.dumps(row).encode(),
            headers={
                "apikey": key,
                "Authorization": f"Bearer {key}",
                "Content-Type": "application/json",
                "Prefer": "resolution=merge-duplicates",
            },
            method="POST",
        )
        urllib.request.urlopen(req, timeout=5)
        state = _load_sync_state(project)
        state["raw/" + rel_path] = content_hash
        _save_sync_state(project, state)
    except Exception:
        pass

# Section grouping for the index, in display order. entities/<type> groups use the
# dir name; overview and docs are their own groups.
ENTITY_ORDER = ["personas", "competitors", "opportunities", "solutions", "objectives", "features", "people"]

# Entity groups whose item count is unbounded (grows with every feedback/discovery
# cycle). Instead of enumerating every page (which bloats the always-loaded index),
# emit a single pointer line to the group's INDEX.md. An agent needing the full list
# drills into that file; the root index stays fast and compact.
UNBOUNDED_ENTITY_GROUPS = {"opportunities", "solutions", "competitors"}

# Entity-section housekeeping files (the opportunities DB's INDEX/LOG/SCHEMA) are not
# entity pages: they carry no page frontmatter and must stay OUT of the always-loaded
# catalog (LOG.md in particular must never enter index.md). Same skiplist the
# opportunities dedup/reindex uses (lib/nanopm.sh).
HOUSEKEEPING = {"INDEX.md", "LOG.md", "SCHEMA.md"}

# Pretty titles for docs/ subfolder collections (prds, tasks, …). Anything not
# listed falls back to a hyphen->space title-case of the folder name.
COLLECTION_TITLES = {
    "prds": "PRDs", "tasks": "Tasks", "handoffs": "Handoffs",
    "weekly-updates": "Weekly Updates", "standups": "Standups",
}


def err(msg: str) -> int:
    print(f"ERROR: {msg}", file=sys.stderr)
    return 1


def wiki_dir(project: str) -> Path:
    return Path(project) / ".nanopm" / "wiki"


def raw_dir(project: str) -> Path:
    return Path(project) / ".nanopm" / "raw"


@contextlib.contextmanager
def wiki_lock(project: str):
    """Serialize mutations to the shared wiki files (index.md, log.md, pages) so
    concurrent ingest runs ("parallel waves", NANOPM-WIKI.md §11) can't tear the
    index or lose a log line. Advisory exclusive flock on .nanopm/wiki/.lock; a
    no-op on non-POSIX hosts. Every writer (reindex, log, and apply) takes the same
    lock, so a reindex never overlaps a log append or a page write."""
    wiki = wiki_dir(project)
    wiki.mkdir(parents=True, exist_ok=True)
    if fcntl is None:
        yield
        return
    with open(wiki / ".lock", "w") as lf:
        fcntl.flock(lf.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lf.fileno(), fcntl.LOCK_UN)


def parse_frontmatter(text: str) -> tuple[dict, str]:
    """Minimal YAML-frontmatter parser (key: value lines only). Returns (fm, body)."""
    if not text.startswith("---"):
        return {}, text
    lines = text.split("\n")
    end = None
    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            end = i
            break
    if end is None:
        return {}, text
    fm: dict[str, str] = {}
    for ln in lines[1:end]:
        if ":" in ln and not ln.lstrip().startswith("#"):
            k, _, v = ln.partition(":")
            fm[k.strip()] = v.strip().strip('"').strip("'")
    return fm, "\n".join(lines[end + 1:])


def summary_line(body: str) -> str:
    """First line under '## Summary', else the first non-heading prose line."""
    lines = body.split("\n")
    for i, ln in enumerate(lines):
        if ln.strip().lower() == "## summary":
            for ln2 in lines[i + 1:]:
                if ln2.strip() and not ln2.startswith("#"):
                    return ln2.strip()
    for ln in lines:
        s = ln.strip()
        if s and not s.startswith("#") and s != "---":
            return s
    return ""


def _truncate(s: str, n: int = 100) -> str:
    s = s.replace("\n", " ").strip()
    return s if len(s) <= n else s[: n - 1].rstrip() + "…"


def collect_pages(wiki: Path) -> dict[str, list[dict]]:
    """Walk the wiki and return {group: [page-meta, ...]}."""
    groups: dict[str, list[dict]] = {}

    def add(group: str, path: Path):
        try:
            text = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return
        fm, body = parse_frontmatter(text)
        rel = path.relative_to(wiki).as_posix()
        title = fm.get("title") or path.stem.replace("-", " ")
        groups.setdefault(group, []).append({
            "path": rel,
            "title": title,
            "type": fm.get("type", group),
            "provenance": fm.get("provenance", ""),
            "last_updated": fm.get("last_updated") or fm.get("generated", ""),
            "summary": _truncate(summary_line(body)),
        })

    for f in sorted((wiki / "overview").glob("*.md")):
        add("overview", f)
    ent = wiki / "entities"
    if ent.is_dir():
        for sub in sorted(p for p in ent.iterdir() if p.is_dir()):
            for f in sorted(sub.glob("*.md")):
                if f.name in HOUSEKEEPING:
                    continue
                add(sub.name, f)
    for f in sorted((wiki / "docs").glob("*.md")):
        add("docs", f)
    return groups


def collect_collections(wiki: Path) -> list[dict]:
    """One bounded entry per docs/ SUBFOLDER collection (prds, tasks, handoffs,
    weekly-updates, standups, …). The flat per-page index (collect_pages) is
    non-recursive on purpose, so dated series can't grow the always-loaded catalog
    unboundedly (NANOPM-WIKI.md §7). This adds a single pointer line per collection
    so an agent still knows the series exists and where to drill in. Generic: any
    docs/ subfolder with markdown is covered, including future series."""
    docs = wiki / "docs"
    if not docs.is_dir():
        return []
    out: list[dict] = []
    for sub in sorted(p for p in docs.iterdir() if p.is_dir()):
        files = sorted(sub.glob("*.md"))
        if not files:
            continue
        latest = ""
        for f in files:
            stem = f.stem
            if len(stem) == 10 and stem[4] == "-" and stem[7] == "-":
                d = stem          # dated-series page: the filename IS the period date
            else:                 # slug-named page (prds/tasks): fall back to frontmatter
                fm, _ = parse_frontmatter(f.read_text(encoding="utf-8", errors="replace"))
                d = fm.get("last_updated") or fm.get("generated") or ""
            if d > latest:
                latest = d
        out.append({
            "title": COLLECTION_TITLES.get(sub.name, sub.name.replace("-", " ").title()),
            "path": sub.relative_to(wiki).as_posix() + "/",
            "count": len(files),
            "latest": latest,
        })
    return out


def cmd_reindex(args) -> int:
    wiki = wiki_dir(args.project)
    if not wiki.is_dir():
        return err(f"{wiki} not found — run nanopm-migrate-to-wiki first")
    groups = collect_pages(wiki)
    order = ["overview"] + ENTITY_ORDER + ["docs"]
    seen = set(order)
    order += [g for g in sorted(groups) if g not in seen]  # any unexpected groups last

    out = ["# Wiki Index", "",
           "_Generated by nanopm-ingest-agent — one line per page. Do not hand-edit._", ""]
    total = 0
    for group in order:
        pages = groups.get(group)
        if not pages:
            continue
        pages.sort(key=lambda p: p["last_updated"], reverse=True)
        out.append(f"## {group.capitalize()}")
        if group in UNBOUNDED_ENTITY_GROUPS:
            # Unbounded collection: emit one pointer line to the group INDEX.md so
            # the root index stays compact. Agent drills in to see individual items.
            n = len(pages)
            latest = pages[0]["last_updated"] if pages else ""
            index_rel = f"entities/{group}/INDEX.md"
            bits = [f"**[{group.capitalize()} ({n})](entities/{group}/INDEX.md)**"]
            if latest:
                bits.append(f"latest {latest}")
            out.append("- " + " · ".join(bits) + f" — see [{index_rel}]({index_rel}) for the full list")
            total += n
        else:
            for p in pages:
                bits = [f"**[{p['title']}]({p['path']})**"]
                if p["provenance"]:
                    bits.append(p["provenance"])
                if p["last_updated"]:
                    bits.append(p["last_updated"])
                line = " · ".join(bits)
                if p["summary"]:
                    line += f" — {p['summary']}"
                out.append(f"- {line}")
                total += 1
        out.append("")

    # Foldered collections (prds/, tasks/, weekly-updates/, standups/, …): one bounded
    # pointer line each, so the catalog surfaces the series without listing every page.
    collections = collect_collections(wiki)
    if collections:
        out.append("## Collections")
        for c in collections:
            n = c["count"]
            bits = [f"**[{c['title']}]({c['path']})**", f"{n} page" + ("" if n == 1 else "s")]
            if c["latest"]:
                bits.append(f"latest {c['latest']}")
            out.append("- " + " · ".join(bits) + " — collection; read the folder for individual pages")
        out.append("")

    # Cross-link the opportunities DB if it lives at the legacy path (pre-backfill).
    opp_index = Path(args.project) / ".nanopm" / "opportunities" / "INDEX.md"
    if opp_index.is_file() and not any((wiki / "entities" / "opportunities").glob("*.md")):
        out.append("## Opportunities")
        out.append("- See [`.nanopm/wiki/entities/opportunities/INDEX.md`](../entities/opportunities/INDEX.md) "
                   "(legacy location — not yet backfilled into entities/).")
        out.append("")

    if not args.dry_run:
        with wiki_lock(args.project):
            (wiki / "index.md").write_text("\n".join(out).rstrip() + "\n", encoding="utf-8")
    msg = f"reindex: {total} page(s) across {sum(1 for g in order if groups.get(g))} group(s)"
    if collections:
        msg += f" + {len(collections)} collection(s)"
    print(msg + (" (dry-run)" if args.dry_run else " -> wiki/index.md"))
    return 0


def cmd_log(args) -> int:
    wiki = wiki_dir(args.project)
    if not wiki.is_dir():
        return err(f"{wiki} not found — run nanopm-migrate-to-wiki first")
    day = _dt.date.today().isoformat()
    line = f"## [{day}] {args.op} | {args.title}"
    lg = wiki / "log.md"
    if not args.dry_run:
        # Locked: log append is read-modify-write, so a concurrent run would
        # otherwise drop a heartbeat line.
        with wiki_lock(args.project):
            existing = lg.read_text(encoding="utf-8") if lg.is_file() else "# Wiki Log\n"
            if not existing.endswith("\n"):
                existing += "\n"
            lg.write_text(existing + line + "\n", encoding="utf-8")
    if not args.dry_run:
        _supabase_log_entry(args.project, args.op, args.title, day)
    print(f"log: {line}" + (" (dry-run)" if args.dry_run else ""))
    return 0


def _norm_citation(s: str) -> str:
    """Normalize a citation for identity comparison: strip a leading markdown
    bullet ("- ") and collapse internal whitespace, so formatting differences
    don't defeat the match (and so trailing spaces don't create false 'NEW's)."""
    s = s.strip()
    if s.startswith("- "):
        s = s[2:]
    return " ".join(s.split())


def resolve_target(project: str, target: str) -> Path | None:
    """Resolve a wiki page path and confine it to .nanopm/wiki/ (no traversal escape).
    Accepts '.nanopm/wiki/...', 'wiki/...', or a bare wiki-relative form like
    'entities/<type>/<slug>.md' / 'docs/<x>.md' / 'overview/<x>.md'. The wiki/ prefix
    is normalized in: an ingest agent that writes a bare 'entities/personas/x.md' must
    NOT land at .nanopm/entities/ (outside the wiki) — every page apply writes belongs
    under .nanopm/wiki/."""
    wiki = (Path(project) / ".nanopm" / "wiki").resolve()
    rel = target
    if rel.startswith(".nanopm/"):
        rel = rel[len(".nanopm/"):]
    if rel.startswith("wiki/"):
        rel = rel[len("wiki/"):]
    dest = (wiki / rel).resolve()
    try:
        dest.relative_to(wiki)
    except ValueError:
        return None
    return dest


def cmd_apply(args) -> int:
    """Write a wiki page directly (content on stdin), under the same .nanopm/wiki/.lock
    every other writer takes — so single-writer-per-file holds (NANOPM-WIKI.md §11).
    This is the deterministic write the ingest/lint agents use now that there is no
    confidence gate: content applies directly; contradictions are surfaced AFTER the
    fact by the judgment lint pass (§9), not held in a pre-write review queue."""
    content = sys.stdin.read()
    if not content:
        return err("no content on stdin")
    dest = resolve_target(args.project, args.target)
    if dest is None:
        return err(f"target {args.target!r} escapes .nanopm/wiki/ — refused")
    with wiki_lock(args.project):
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(content, encoding="utf-8")
    print(f"APPLIED {args.target}")
    # Push to Supabase when configured — best-effort, non-blocking.
    rel = dest.relative_to(wiki_dir(args.project)).as_posix()
    _supabase_upsert_page(args.project, rel, content)
    return 0


def cmd_citation_check(args) -> int:
    """Dedup gate: is this citation already on the page? The citation IS the
    identity (NANOPM-WIKI.md §5). We match it against each existing citation LINE
    (normalized, anchored to a whole line) — NOT as a raw substring of the page.
    A substring test false-matches short citations (e.g. "terminal" inside "I live
    in the terminal" — interview, 2026-06-23) and drops distinct records, which is
    the exact dedup bug the wiki is meant to fix. Returns 0=DUPLICATE, 1=NEW so a
    caller can branch on the exit code."""
    cit = args.citation.strip()
    if not cit:
        print("ERROR: empty citation", file=sys.stderr)
        return 2
    target = Path(args.project) / ".nanopm" / (
        args.target[len(".nanopm/"):] if args.target.startswith(".nanopm/") else args.target)
    if not target.is_file():
        print("NEW")          # page doesn't exist yet -> definitely new
        return 1
    body = target.read_text(encoding="utf-8", errors="replace")
    needle = _norm_citation(cit)
    for line in body.splitlines():
        if _norm_citation(line) == needle:
            print("DUPLICATE")
            return 0
    print("NEW")
    return 1


RAW_ID_LEN = 12  # first 12 hex of sha256, matching nanopm_archive_raw (lib/nanopm.sh)


def raw_id(data: bytes) -> str:
    """Content hash for the raw archive: first 12 hex of sha256. MUST match the
    bash helper nanopm_archive_raw so a Python pre-check and the actual archive
    write agree on the id (and therefore on the archived filename)."""
    return hashlib.sha256(data).hexdigest()[:RAW_ID_LEN]


def cmd_raw_check(args) -> int:
    """Raw-dedup affordance: is a content hash already archived under
    .nanopm/raw/<type>/? Lets a caller skip re-writing an identical source before
    invoking the bash archiver (NANOPM-WIKI.md §2.1). The id is content-addressed,
    so this only needs the hash + type. Provide --hash directly, or pipe the source
    content on stdin and we hash it the same way nanopm_archive_raw does. Prints the
    resolved id; returns 0=DUPLICATE (already archived), 1=NEW so a caller can branch
    on the exit code (mirrors citation-check)."""
    if args.hash:
        rid = "".join(c for c in args.hash.strip().lower() if c in "0123456789abcdef")[:RAW_ID_LEN]
        if not rid:
            print("ERROR: --hash is not a hex digest", file=sys.stderr)
            return 2
    else:
        data = sys.stdin.buffer.read()
        if not data:
            print("ERROR: no --hash and no content on stdin", file=sys.stderr)
            return 2
        rid = raw_id(data)
    rtype = "".join(c for c in args.type.lower() if c.isalnum() or c == "-")
    if not rtype:
        print("ERROR: invalid --type", file=sys.stderr)
        return 2
    raw_dir = Path(args.project) / ".nanopm" / "raw" / rtype
    # Content-addressed: id is fixed, extension is not — any raw/<type>/<id>.* counts.
    existing = sorted(raw_dir.glob(f"{rid}.*")) if raw_dir.is_dir() else []
    existing = [p for p in existing if not p.name.endswith(".manifest.jsonl")]
    if existing:
        print(f"DUPLICATE {rid} {existing[0].relative_to(Path(args.project) / '.nanopm').as_posix()}")
        return 0
    print(f"NEW {rid}")
    return 1



# ---------------------------------------------------------------------------
# Search layer — SQLite FTS5 index over wiki entity and docs pages.
# The DB is a derived artifact (gitignored); it auto-rebuilds from the wiki
# files which ARE in git, so a fresh clone always gets correct results.
# ---------------------------------------------------------------------------

SEARCH_DB = "search.db"


def search_db_path(project: str) -> Path:
    return Path(project) / ".nanopm" / SEARCH_DB


def collect_search_pages(wiki: Path) -> list[dict]:
    """Collect all indexable wiki pages (entities + docs) with their metadata."""
    pages: list[dict] = []

    def _add(rtype: str, f: Path) -> None:
        try:
            text = f.read_text(encoding="utf-8", errors="replace")
        except OSError:
            return
        fm, body = parse_frontmatter(text)
        pages.append({
            "slug": f.stem,
            "type": rtype,
            "path": f.relative_to(wiki).as_posix(),
            "title": fm.get("title", f.stem.replace("-", " ")),
            "theme": fm.get("theme", ""),
            "provenance": fm.get("provenance", ""),
            "priority": fm.get("priority", ""),
            "summary": _truncate(summary_line(body), 200),
            "body": body,
        })

    ent = wiki / "entities"
    if ent.is_dir():
        for sub in sorted(p for p in ent.iterdir() if p.is_dir()):
            for f in sorted(sub.glob("*.md")):
                if f.name not in HOUSEKEEPING:
                    _add(sub.name, f)

    docs = wiki / "docs"
    if docs.is_dir():
        for f in sorted(docs.glob("*.md")):
            _add("docs", f)

    return pages


def _is_search_stale(project: str) -> bool:
    """True if any wiki markdown file is newer than the search DB, or DB missing."""
    db = search_db_path(project)
    if not db.exists():
        return True
    db_mtime = db.stat().st_mtime
    wiki = wiki_dir(project)
    return any(f.stat().st_mtime > db_mtime for f in wiki.rglob("*.md"))


def _build_search_index(project: str) -> int:
    wiki = wiki_dir(project)
    if not wiki.is_dir():
        return err(f"{wiki} not found — run nanopm-migrate-to-wiki first")
    pages = collect_search_pages(wiki)
    db = search_db_path(project)
    conn = sqlite3.connect(db)
    try:
        conn.execute("DROP TABLE IF EXISTS wiki_fts")
        conn.execute("""
            CREATE VIRTUAL TABLE wiki_fts USING fts5(
                slug UNINDEXED,
                type UNINDEXED,
                provenance UNINDEXED,
                priority UNINDEXED,
                path UNINDEXED,
                title,
                theme,
                summary,
                body,
                tokenize = 'porter unicode61'
            )
        """)
        conn.executemany(
            "INSERT INTO wiki_fts VALUES (?,?,?,?,?,?,?,?,?)",
            [(p["slug"], p["type"], p["provenance"], p["priority"],
              p["path"], p["title"], p["theme"], p["summary"], p["body"])
             for p in pages],
        )
        conn.commit()
    finally:
        conn.close()
    print(f"search-index: {len(pages)} page(s) indexed -> {db}")
    return 0


def cmd_sync(args) -> int:
    """Push all local wiki pages to Supabase (bulk upsert). Used for initial
    setup or after a bulk import (e.g. a teammate sharing their wiki)."""
    wiki = wiki_dir(args.project)
    if not wiki.is_dir():
        return err(f"{wiki} not found — run nanopm-migrate-to-wiki first")
    url, key = _supabase_creds()
    if not url or not key:
        return err("Supabase not configured — set NANOPM_SUPABASE_URL and NANOPM_SUPABASE_KEY in ~/.nanopm/.env")
    # Derived files (regenerated on every reindex) must not be synced:
    # - index.md / log.md at the wiki root
    # - INDEX.md / LOG.md inside every entities/<type>/ dir
    # SCHEMA.md is user-editable and written once at bootstrap — it is NOT derived
    # and must be pushed/pulled like any other wiki file.
    SKIP_ON_SYNC = {"index.md", "log.md", "INDEX.md", "LOG.md"}
    pushed = 0
    for f in sorted(wiki.rglob("*.md")):
        if f.name in SKIP_ON_SYNC:
            continue
        content = f.read_text(encoding="utf-8", errors="replace")
        rel = f.relative_to(wiki).as_posix()
        _supabase_upsert_page(args.project, rel, content)
        pushed += 1
    try:
        _slug_hint = url.split("//")[1].split(".")[0]
    except (IndexError, AttributeError):
        _slug_hint = "?"
    print(f"sync: pushed {pushed} page(s) to Supabase ({_slug_hint})")
    raw = raw_dir(args.project)
    raw_pushed = 0
    if raw.is_dir():
        for f in sorted(raw.rglob("*")):
            if f.is_dir():
                continue
            rel = f.relative_to(raw).as_posix()
            try:
                content = f.read_text(encoding="utf-8")
            except (UnicodeDecodeError, OSError):
                continue  # skip binary or unreadable files
            _supabase_upsert_raw(args.project, rel, content)
            raw_pushed += 1
    print(f"sync: pushed {raw_pushed} raw source(s) to Supabase")
    return 0


def cmd_pull(args) -> int:
    """Fetch wiki pages updated on Supabase and write them locally. Newest wins
    on conflict (last_updated comparison); local wins on tie. Hand edits detected
    via content hash are skipped rather than silently overwritten. Runs reindex
    after pulling new pages. No-op when Supabase is not configured."""
    url, key = _supabase_creds()
    if not url or not key:
        return 0  # not configured — silent no-op
    project_slug = Path(args.project).resolve().name
    try:
        endpoint = (
            f"{url}/rest/v1/{SUPABASE_PAGES_TABLE}"
            f"?project_slug=eq.{urllib.parse.quote(project_slug, safe='')}&select=path,content,last_updated"
        )
        req = urllib.request.Request(
            endpoint,
            headers={"apikey": key, "Authorization": f"Bearer {key}"},
        )
        rows = _json.loads(urllib.request.urlopen(req, timeout=10).read())
    except Exception:
        return 0  # best-effort
    wiki = wiki_dir(args.project)
    state = _load_sync_state(args.project)
    pulled = 0
    skipped_edits = 0
    for row in rows:
        try:
            dest = wiki / row["path"]
            dest.resolve().relative_to(wiki.resolve())
        except (ValueError, TypeError):
            continue  # skip — bad path or path escapes wiki dir
        if not row.get("content"):
            continue  # skip null/empty content — never write an empty file from a remote row
        if dest.is_file():
            local_content = dest.read_text(encoding="utf-8", errors="replace")
            stored_hash = state.get(row["path"])
            if stored_hash is None or _content_hash(local_content) != stored_hash:
                # Local file was never synced (stored_hash is None) or was modified
                # since the last sync (hash mismatch). Protect it rather than silently
                # overwriting — the user can run 'sync' to push their version first.
                skipped_edits += 1
                continue
            local_fm, _ = parse_frontmatter(local_content)
            local_ts = (local_fm.get("last_updated") or local_fm.get("generated", ""))[:10]
            remote_ts = (row.get("last_updated") or "")[:10]
            if local_ts >= remote_ts:
                continue  # local is current or newer (and unmodified since last sync)
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(row["content"], encoding="utf-8")
        state[row["path"]] = _content_hash(row.get("content") or "")
        pulled += 1
    _save_sync_state(args.project, state)
    if pulled:
        import argparse as _ap
        cmd_reindex(_ap.Namespace(project=args.project, dry_run=False))
    if skipped_edits:
        print(f"pull: {pulled} page(s) updated, {skipped_edits} skipped (local edits detected — run 'sync' to push your changes first)")
    else:
        print(f"pull: {pulled} page(s) updated from Supabase")
    cmd_raw_pull(args)
    return 0


def cmd_raw_pull(args) -> int:
    """Fetch raw sources from Supabase and write them locally. Hand edits
    detected via content hash are skipped. No-op when Supabase not configured."""
    url, key = _supabase_creds()
    if not url or not key:
        return 0
    project_slug = Path(args.project).resolve().name
    try:
        endpoint = (
            f"{url}/rest/v1/{SUPABASE_RAW_TABLE}"
            f"?project_slug=eq.{urllib.parse.quote(project_slug, safe='')}&select=path,content,content_hash"
        )
        req = urllib.request.Request(
            endpoint,
            headers={"apikey": key, "Authorization": f"Bearer {key}"},
        )
        rows = _json.loads(urllib.request.urlopen(req, timeout=10).read())
    except Exception:
        return 0
    raw = raw_dir(args.project)
    state = _load_sync_state(args.project)
    pulled = 0
    skipped_edits = 0
    for row in rows:
        try:
            state_key = "raw/" + row["path"]
            dest = raw / row["path"]
            dest.resolve().relative_to(raw.resolve())
        except (ValueError, TypeError):
            continue  # skip — bad path or path escapes raw dir
        if not row.get("content"):
            continue  # skip null/empty content
        if dest.is_file():
            local_content = dest.read_text(encoding="utf-8", errors="replace")
            stored_hash = state.get(state_key)
            if stored_hash and _content_hash(local_content) != stored_hash:
                skipped_edits += 1
                continue
            remote_hash = row.get("content_hash") or ""
            if remote_hash and _content_hash(local_content) == remote_hash:
                continue  # already in sync
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(row["content"], encoding="utf-8")
        state[state_key] = _content_hash(row["content"])
        pulled += 1
    _save_sync_state(args.project, state)
    if skipped_edits:
        print(f"raw-pull: {pulled} file(s) updated, {skipped_edits} skipped (local edits — run 'sync' to push first)")
    else:
        print(f"raw-pull: {pulled} file(s) updated from Supabase")
    return 0


def cmd_push_file(args) -> int:
    """Push a single existing wiki file to Supabase by its wiki-relative path.
    Called automatically by nanopm_wiki_doc_log after every skill write so doc
    pages reach Supabase without a manual 'sync' step."""
    url, key = _supabase_creds()
    if not url or not key:
        return 0  # not configured — silent no-op
    wiki = wiki_dir(args.project)
    dest = (wiki / args.target).resolve()
    # Security: path must stay inside the wiki directory
    try:
        dest.relative_to(wiki.resolve())
    except ValueError:
        return err(f"target {args.target!r} escapes wiki — refused")
    if not dest.is_file():
        return 0  # file may not exist yet on first call — silent no-op
    content = dest.read_text(encoding="utf-8", errors="replace")
    _supabase_upsert_page(args.project, args.target, content)
    print(f"pushed: {args.target}")
    return 0


def cmd_search_index(args) -> int:
    """Force-rebuild the FTS5 search index unconditionally."""
    return _build_search_index(args.project)


def cmd_search(args) -> int:
    """Query the FTS5 index. Auto-rebuilds from wiki files if the DB is stale
    or missing (e.g. fresh clone — the wiki files are in git, the DB is not)."""
    if _is_search_stale(args.project):
        rc = _build_search_index(args.project)
        if rc != 0:
            return rc

    db = search_db_path(args.project)
    # Use FTS5's implicit AND (space-separated) so results are precise.
    # OR-joining was too broad — "user loses context between sessions" would
    # match almost everything via "user OR sessions". Let the LLM reformulate
    # with synonyms and fire 2–3 targeted queries instead.
    # Porter stemming (configured at index-build time) handles "session/sessions".
    import re as _re
    terms = [t for t in _re.findall(r'\w+', args.query) if len(t) > 2]
    fts_query = " ".join(terms) if terms else args.query

    # The index stores types as directory names (plural: "opportunities",
    # "personas", …) but skill files historically passed singular forms
    # ("opportunity", "persona", …). Normalize at query time so both work.
    _TYPE_ALIASES = {
        "opportunity": "opportunities",
        "persona": "personas",
        "competitor": "competitors",
        "solution": "solutions",
        "objective": "objectives",
        "feature": "features",
        "person": "people",
        "doc": "docs",
    }
    qtype = _TYPE_ALIASES.get(args.type, args.type) if args.type else args.type

    conn = sqlite3.connect(db)
    try:
        if qtype:
            rows = conn.execute(
                "SELECT slug, type, path, title, provenance, priority, summary "
                "FROM wiki_fts WHERE wiki_fts MATCH ? AND type = ? "
                "ORDER BY rank LIMIT ?",
                (fts_query, qtype, args.limit),
            ).fetchall()
            # FTS keyword miss but type is known — fall back to type-only scan
            # so discovery queries (load all opportunities) never silently fail.
            if not rows:
                rows = conn.execute(
                    "SELECT slug, type, path, title, provenance, priority, summary "
                    "FROM wiki_fts WHERE type = ? LIMIT ?",
                    (qtype, args.limit),
                ).fetchall()
        else:
            rows = conn.execute(
                "SELECT slug, type, path, title, provenance, priority, summary "
                "FROM wiki_fts WHERE wiki_fts MATCH ? "
                "ORDER BY rank LIMIT ?",
                (fts_query, args.limit),
            ).fetchall()
    except sqlite3.OperationalError as exc:
        return err(f"search query failed: {exc}")
    finally:
        conn.close()

    if not rows:
        print("NO_RESULTS")
        return 0

    for slug, rtype, path, title, provenance, priority, summary in rows:
        parts = [slug, rtype, path, title, provenance, priority, summary]
        print("\t".join(parts))
    return 0


def cmd_status(args) -> int:
    """Show which local wiki pages have been modified since the last Supabase sync.
    Reads the local sync-state hash file — does not contact Supabase."""
    wiki = wiki_dir(args.project)
    if not wiki.is_dir():
        return err(f"{wiki} not found — run nanopm-migrate-to-wiki first")
    state = _load_sync_state(args.project)
    SKIP = {"index.md", "log.md", "INDEX.md", "LOG.md"}  # SCHEMA.md is user-editable — track it
    modified, clean, untracked = [], [], []
    for f in sorted(wiki.rglob("*.md")):
        if f.name in SKIP:
            continue
        rel = str(f.relative_to(wiki))
        content = f.read_text(encoding="utf-8", errors="replace")
        stored = state.get(rel)
        if stored is None:
            untracked.append(rel)
        elif _content_hash(content) == stored:
            clean.append(rel)
        else:
            modified.append(rel)
    print(f"sync status: {len(clean)} in sync · {len(modified)} modified locally · {len(untracked)} never synced")
    for p in modified:
        print(f"  M {p}")
    for p in untracked:
        print(f"  ? {p}")
    raw = raw_dir(args.project)
    raw_modified, raw_clean, raw_untracked = [], [], []
    if raw.is_dir():
        for f in sorted(raw.rglob("*")):
            if f.is_dir():
                continue
            rel = f.relative_to(raw).as_posix()
            try:
                content = f.read_text(encoding="utf-8")
            except (UnicodeDecodeError, OSError):
                continue  # skip binary or unreadable files
            stored = state.get("raw/" + rel)
            if stored is None:
                raw_untracked.append(rel)
            elif _content_hash(content) == stored:
                raw_clean.append(rel)
            else:
                raw_modified.append(rel)
    print(f"raw sync status: {len(raw_clean)} in sync · {len(raw_modified)} modified locally · {len(raw_untracked)} never synced")
    for p in raw_modified:
        print(f"  M {p}")
    for p in raw_untracked:
        print(f"  ? {p}")
    return 0


def cmd_remote_status(args) -> int:
    """Check how many Supabase pages are newer than local. Fetches only path +
    last_updated metadata (no content) — fast enough to run on every explicit
    refresh. Prints 'remote status: N page(s) to pull'. No-op if not configured."""
    url, key = _supabase_creds()
    if not url or not key:
        print("remote status: 0 page(s) to pull")
        return 0
    project_slug = Path(args.project).resolve().name
    try:
        endpoint = (
            f"{url}/rest/v1/{SUPABASE_PAGES_TABLE}"
            f"?project_slug=eq.{urllib.parse.quote(project_slug, safe='')}&select=path,last_updated"
        )
        req = urllib.request.Request(
            endpoint,
            headers={"apikey": key, "Authorization": f"Bearer {key}"},
        )
        rows = _json.loads(urllib.request.urlopen(req, timeout=10).read())
    except Exception:
        print("remote status: 0 page(s) to pull")
        return 0
    wiki = wiki_dir(args.project)
    state = _load_sync_state(args.project)
    to_pull = 0
    for row in rows:
        dest = wiki / row["path"]
        try:
            dest.resolve().relative_to(wiki.resolve())
        except ValueError:
            continue  # path escapes wiki dir — skip
        remote_ts = row.get("last_updated") or ""
        if dest.is_file():
            local_content = dest.read_text(encoding="utf-8", errors="replace")
            stored_hash = state.get(row["path"])
            # Respect the same hand-edit protection as cmd_pull: skip files the
            # user modified locally so we don't flag them as "pull needed" when
            # the local edit should win.
            if stored_hash and _content_hash(local_content) != stored_hash:
                continue
            local_fm, _ = parse_frontmatter(local_content)
            local_ts = (local_fm.get("last_updated") or local_fm.get("generated", ""))[:10]
            if local_ts >= remote_ts[:10]:
                continue  # local is current or newer
        to_pull += 1
    print(f"remote status: {to_pull} page(s) to pull")
    return 0


def cmd_push_pending(args) -> int:
    """Push only local wiki pages and raw files that differ from the last sync
    (modified locally or never synced). O(pending) not O(all) — fast catch-up
    after a failed inline auto-push. No-op when Supabase not configured."""
    url, key = _supabase_creds()
    if not url or not key:
        return 0  # not configured — silent no-op
    wiki = wiki_dir(args.project)
    if not wiki.is_dir():
        return 0
    state = _load_sync_state(args.project)
    SKIP = {"index.md", "log.md", "INDEX.md", "LOG.md"}
    pushed = 0
    for f in sorted(wiki.rglob("*.md")):
        if f.name in SKIP:
            continue
        rel = f.relative_to(wiki).as_posix()
        content = f.read_text(encoding="utf-8", errors="replace")
        stored = state.get(rel)
        if stored is not None and _content_hash(content) == stored:
            continue  # already in sync
        _supabase_upsert_page(args.project, rel, content)
        pushed += 1
    raw = raw_dir(args.project)
    raw_pushed = 0
    if raw.is_dir():
        for f in sorted(raw.rglob("*")):
            if f.is_dir():
                continue
            rel = f.relative_to(raw).as_posix()
            try:
                content = f.read_text(encoding="utf-8")
            except (UnicodeDecodeError, OSError):
                continue  # skip binary or unreadable files
            stored = state.get("raw/" + rel)
            if stored is not None and _content_hash(content) == stored:
                continue  # already in sync
            _supabase_upsert_raw(args.project, rel, content)
            raw_pushed += 1
    print(f"push-pending: {pushed} page(s) pushed, {raw_pushed} raw file(s) pushed")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("--project", default=".", help="project root containing .nanopm/ (default: .)")
    sub = ap.add_subparsers(dest="cmd", required=True)

    r = sub.add_parser("reindex", help="regenerate wiki/index.md")
    r.add_argument("--dry-run", action="store_true")
    r.set_defaults(func=cmd_reindex)

    l = sub.add_parser("log", help="append a heartbeat line to wiki/log.md")
    l.add_argument("--op", required=True, help="ingest | query | lint | migrate")
    l.add_argument("--title", required=True)
    l.add_argument("--dry-run", action="store_true")
    l.set_defaults(func=cmd_log)

    c = sub.add_parser("citation-check", help="is a citation already on a page?")
    c.add_argument("--target", required=True, help="wiki page path (under .nanopm/)")
    c.add_argument("--citation", required=True, help="the verbatim citation string")
    c.set_defaults(func=cmd_citation_check)

    a = sub.add_parser("apply", help="write a wiki page directly (content on stdin)")
    a.add_argument("--target", required=True, help="wiki page path (under .nanopm/)")
    a.set_defaults(func=cmd_apply)

    rc = sub.add_parser("raw-check", help="is a raw source already archived? (content-hash dedup)")
    rc.add_argument("--type", required=True, help="raw subdir: feedback | interviews | data | …")
    rc.add_argument("--hash", default="", help="content hash to check; omit to hash stdin instead")
    rc.set_defaults(func=cmd_raw_check)

    sy = sub.add_parser("sync", help="push all local wiki pages to Supabase (bulk upsert)")
    sy.set_defaults(func=cmd_sync)

    pp = sub.add_parser("push-pending", help="push only modified/untracked wiki pages to Supabase (fast catch-up)")
    pp.set_defaults(func=cmd_push_pending)

    rs = sub.add_parser("remote-status", help="check how many Supabase pages are newer than local (metadata only)")
    rs.set_defaults(func=cmd_remote_status)

    pl = sub.add_parser("pull", help="fetch wiki pages and raw sources updated on Supabase to local")
    pl.set_defaults(func=cmd_pull)

    rpl = sub.add_parser("raw-pull", help="fetch raw sources from Supabase (wiki-only pull: use 'pull')")
    rpl.set_defaults(func=cmd_raw_pull)

    pf = sub.add_parser("push-file", help="push a single wiki file to Supabase (auto-called by nanopm_wiki_doc_log)")
    pf.add_argument("--target", required=True, help="wiki-relative path (e.g. docs/retro-2026-07-02.md)")
    pf.set_defaults(func=cmd_push_file)

    st = sub.add_parser("status", help="show pages modified locally since the last Supabase sync")
    st.set_defaults(func=cmd_status)

    si = sub.add_parser("search-index", help="build/rebuild the SQLite FTS5 search index")
    si.set_defaults(func=cmd_search_index)

    se = sub.add_parser("search", help="query the search index (auto-rebuilds if stale)")
    se.add_argument("--query", required=True, help="search terms")
    se.add_argument("--type", default="", help="filter by entity type: opportunities | solutions | personas | docs | …")
    se.add_argument("--limit", type=int, default=5, help="max results (default: 5)")
    se.set_defaults(func=cmd_search)

    args = ap.parse_args()
    return args.func(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
