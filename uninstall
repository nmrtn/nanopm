#!/usr/bin/env bash
# nanopm uninstall — remove nanopm skills from all installed agents
# Usage: bash uninstall
#        bash uninstall --purge   (also removes ~/.nanopm config and memory)
set -euo pipefail

GLOBAL_CONFIG_DIR="$HOME/.nanopm"
# Keep in sync with setup's _SKILL_LIST; pm-scan and pm-audit are legacy names kept so old installs get cleaned up
_SKILL_LIST="pm-vision-mission pm-business-model pm-org pm-product pm-personas pm-discovery pm-challenge-me pm-objectives pm-strategy pm-roadmap pm-prd pm-breakdown pm-retro pm-run pm-upgrade pm-user-feedback pm-competitors-intel pm-interview pm-standup pm-weekly-update pm-data pm-scan pm-audit"

# ── colors ────────────────────────────────────────────────────────────────────
_bold()  { printf '\033[1m%s\033[0m' "$*"; }
_green() { printf '\033[0;32m%s\033[0m' "$*"; }
_yellow(){ printf '\033[0;33m%s\033[0m' "$*"; }
_red()   { printf '\033[0;31m%s\033[0m' "$*"; }

step() { echo; printf '  %s %s\n' "$(_bold '→')" "$*"; }
ok()   { printf '  %s %s\n' "$(_green '✓')" "$*"; }
warn() { printf '  %s %s\n' "$(_yellow '⚠')" "$*"; }
fail() { printf '  %s %s\n' "$(_red '✗')" "$*"; echo; exit 1; }

_PURGE=0
for arg in "$@"; do
  [ "$arg" = "--purge" ] && _PURGE=1
done

echo
echo "  $(_bold 'nanopm uninstall')"
echo

# ── remove installed skills from all known host directories ──────────────────
step "Removing skills"
_REMOVED=0
for _dir in \
  "$HOME/.claude/skills" \
  "$HOME/.vibe/skills" \
  "$HOME/.codex/skills" \
  "$HOME/.agents/skills"
do
  [ -d "$_dir" ] || continue
  _host=$(basename "$(dirname "$_dir")" | tr -d '.')
  _found=0
  for skill in $_SKILL_LIST; do
    if [ -d "$_dir/$skill" ]; then
      rm -rf "$_dir/$skill"
      _found=$(( _found + 1 ))
      _REMOVED=$(( _REMOVED + 1 ))
    fi
  done
  [ "$_found" -gt 0 ] && ok "[$_host] removed $_found skills from $_dir"
done

if [ "$_REMOVED" -eq 0 ]; then
  warn "No nanopm skills found in any agent directory"
fi

# ── purge global config and memory (opt-in only) ──────────────────────────────
if [ "$_PURGE" -eq 1 ]; then
  step "Purging global config and memory at $GLOBAL_CONFIG_DIR"
  if [ -d "$GLOBAL_CONFIG_DIR" ]; then
    # Safety check — don't purge if it looks like it has user data beyond nanopm
    _MEMORY_SIZE=$(du -sh "$GLOBAL_CONFIG_DIR/memory" 2>/dev/null | cut -f1 || echo "0")
    echo "  Memory size: $_MEMORY_SIZE"
    echo
    printf "  This will permanently delete all nanopm memory and config. Continue? [y/N] "
    read -r _CONFIRM
    if [ "$_CONFIRM" = "y" ] || [ "$_CONFIRM" = "Y" ]; then
      rm -rf "$GLOBAL_CONFIG_DIR"
      ok "~/.nanopm removed"
    else
      warn "Skipped — ~/.nanopm kept"
    fi
  else
    ok "~/.nanopm not found — nothing to purge"
  fi
else
  echo
  echo "  $(_yellow 'Note:') ~/.nanopm/ (config + memory) was kept."
  echo "  Run $(_bold 'bash uninstall --purge') to also remove it."
fi

# ── done ──────────────────────────────────────────────────────────────────────
echo
echo "  $(_bold "$(_green 'nanopm uninstalled.')")"
echo
echo "  To reinstall:"
echo "   curl -fsSL https://raw.githubusercontent.com/nmrtn/nanopm/main/setup | bash"
echo
