#!/usr/bin/env python3
"""nanopm-confidence-gate — gate writes to the memory wiki by confidence.

Part of the memory-wiki redesign (issue #103). The ingest and lint agents propose
writes to wiki pages; this primitive decides whether a write auto-applies or is held
for human review, so the agents never silently overwrite correct knowledge.

Policy (NANOPM-WIKI.md §11):
  - confidence >= threshold (default 7, on a 1-10 scale) AND not a reversal -> APPLY
  - confidence <  threshold, OR --reversal (e.g. a strategy reversal / ambiguous
    edge type / low-confidence match)            -> hold in the review surface

Review surface: .nanopm/wiki/_review/<id>.json — one pending write per file, holding
the target path, confidence, reason, and the proposed content. Nothing touches the
target until a human approves.

Usage:
  # propose a write (content on stdin):
  nanopm-confidence-gate apply --target wiki/entities/personas/theo.md \\
      --confidence 8 [--reason "..."] [--reversal] [--threshold 7] < content.md
  nanopm-confidence-gate list                 # pending reviews
  nanopm-confidence-gate show <id>            # print a pending write's content
  nanopm-confidence-gate approve <id>         # apply a held write, clear the review
  nanopm-confidence-gate reject <id>          # discard a held write

Output (stdout, parseable):
  APPLIED <target>      | REVIEW <id> <target>     | REJECTED <id>
Exit codes: 0 ok, 1 error, 2 bad usage.
"""
from __future__ import annotations

import argparse
import datetime as _dt
import hashlib
import json
import re
import sys
from pathlib import Path

DEFAULT_THRESHOLD = 7
# Review ids are basename + sha1 hex (see review_id); a well-formed id never
# contains a path separator. Validate before using an id in a filesystem path
# so a crafted id (e.g. "../../etc/x") can't escape the review dir.
_ID_RE = re.compile(r"^[A-Za-z0-9._-]+$")


def err(msg: str) -> int:
    print(f"ERROR: {msg}", file=sys.stderr)
    return 1


def nano_dir(project: str) -> Path:
    return Path(project) / ".nanopm"


def review_dir(project: str) -> Path:
    return nano_dir(project) / "wiki" / "_review"


def resolve_target(project: str, target: str) -> Path | None:
    """Resolve a target path and confine it to .nanopm/ (no traversal escape)."""
    nano = nano_dir(project).resolve()
    # Accept both ".nanopm/wiki/..." and "wiki/..." forms.
    t = target
    rel = t[len(".nanopm/"):] if t.startswith(".nanopm/") else t
    dest = (nano / rel).resolve()
    try:
        dest.relative_to(nano)
    except ValueError:
        return None
    return dest


def review_id(target: str, content: str) -> str:
    h = hashlib.sha1(f"{target}\n{content}".encode("utf-8")).hexdigest()[:10]
    base = target.rstrip("/").split("/")[-1].replace(".md", "") or "page"
    return f"{base}-{h}"


def cmd_apply(args) -> int:
    content = sys.stdin.read()
    if not content:
        return err("no content on stdin")
    dest = resolve_target(args.project, args.target)
    if dest is None:
        return err(f"target {args.target!r} escapes .nanopm/ — refused")
    high_conf = args.confidence >= args.threshold
    if high_conf and not args.reversal:
        dest.parent.mkdir(parents=True, exist_ok=True)
        dest.write_text(content, encoding="utf-8")
        print(f"APPLIED {args.target}")
        return 0
    # Hold for review.
    rid = review_id(args.target, content)
    rdir = review_dir(args.project)
    rdir.mkdir(parents=True, exist_ok=True)
    record = {
        "id": rid,
        "target": args.target,
        "confidence": args.confidence,
        "threshold": args.threshold,
        "reversal": bool(args.reversal),
        "reason": args.reason or "",
        "ts": _dt.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ"),
        "content": content,
    }
    (rdir / f"{rid}.json").write_text(
        json.dumps(record, ensure_ascii=False, indent=2), encoding="utf-8")
    why = "reversal" if args.reversal else f"confidence {args.confidence} < {args.threshold}"
    print(f"REVIEW {rid} {args.target}  ({why})")
    return 0


def _load_review(project: str, rid: str) -> tuple[Path, dict] | None:
    if not _ID_RE.match(rid or ""):  # reject path-separator / traversal ids
        return None
    rf = review_dir(project) / f"{rid}.json"
    if not rf.is_file():
        return None
    try:
        return rf, json.loads(rf.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return None


def cmd_list(args) -> int:
    rdir = review_dir(args.project)
    rows = sorted(rdir.glob("*.json")) if rdir.is_dir() else []
    if not rows:
        print("no pending reviews")
        return 0
    print(f"{len(rows)} pending review(s):")
    for rf in rows:
        try:
            r = json.loads(rf.read_text(encoding="utf-8"))
        except Exception:
            print(f"  {rf.stem} (unreadable)")
            continue
        why = "reversal" if r.get("reversal") else f"conf {r.get('confidence')}<{r.get('threshold')}"
        reason = f" — {r['reason']}" if r.get("reason") else ""
        print(f"  {r['id']}  -> {r['target']}  ({why}){reason}")
    return 0


def cmd_show(args) -> int:
    found = _load_review(args.project, args.id)
    if not found:
        return err(f"no pending review {args.id!r}")
    _, r = found
    sys.stdout.write(r.get("content", ""))
    return 0


def cmd_approve(args) -> int:
    found = _load_review(args.project, args.id)
    if not found:
        return err(f"no pending review {args.id!r}")
    rf, r = found
    target = r.get("target")
    if not target:
        return err(f"review {args.id!r} is missing its target field")
    dest = resolve_target(args.project, target)
    if dest is None:
        return err(f"target {target!r} escapes .nanopm/ — refused")
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_text(r.get("content", ""), encoding="utf-8")
    rf.unlink()
    print(f"APPLIED {r['target']}")
    return 0


def cmd_reject(args) -> int:
    found = _load_review(args.project, args.id)
    if not found:
        return err(f"no pending review {args.id!r}")
    rf, _ = found
    rf.unlink()
    print(f"REJECTED {args.id}")
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("--project", default=".", help="project root containing .nanopm/ (default: .)")
    sub = ap.add_subparsers(dest="cmd", required=True)

    a = sub.add_parser("apply", help="propose a write (content on stdin)")
    a.add_argument("--target", required=True, help="wiki page path (under .nanopm/)")
    a.add_argument("--confidence", type=int, required=True, help="1-10")
    a.add_argument("--threshold", type=int, default=DEFAULT_THRESHOLD)
    a.add_argument("--reversal", action="store_true", help="force review (reversal / ambiguous)")
    a.add_argument("--reason", default="")
    a.set_defaults(func=cmd_apply)

    for name, fn, helptext in (
        ("list", cmd_list, "show pending reviews"),
        ("show", cmd_show, "print a pending write's content"),
        ("approve", cmd_approve, "apply a held write"),
        ("reject", cmd_reject, "discard a held write"),
    ):
        p = sub.add_parser(name, help=helptext)
        if name in ("show", "approve", "reject"):
            p.add_argument("id", help="review id (from `list`)")
        p.set_defaults(func=fn)

    args = ap.parse_args()
    if getattr(args, "cmd", None) == "apply" and not (1 <= args.confidence <= 10):
        return err("--confidence must be 1-10")
    return args.func(args)


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
